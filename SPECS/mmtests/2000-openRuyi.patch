 	"suse"		=> "zypper install",
 	"debian"	=> "apt-get install",
 	"redhat"	=> "yum install",
+	"openruyi"	=> "dnf install",
 );
 
 my %force_install = (
 	"suse" => "",
 	"debian" => "",
 	"redhat" => "",
+	"openruyi" => "",
 );
 
