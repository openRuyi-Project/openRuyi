 		$distro = $release_file;
 		$distro =~ tr/[A-Z]/[a-z]/;
@@ -276,6 +297,7 @@ foreach my $package (@ARGV) {
 		$force_install{"suse"} = "-y";
 		$force_install{"debian"} = "-y";
 		$force_install{"redhat"} = "-y";
+		$force_install{"openruyi"} = "-y";
 		$noninteractive_install{"debian"} = "DEBIAN_FRONTEND=noninteractive";
