From 95d15af782faf42fff3c5156486340a6c83f78ac Mon Sep 17 00:00:00 2001
From: Vivian Wang <wangruikang@iscas.ac.cn>
Date: Mon, 30 Mar 2026 10:14:59 +0800
Subject: [PATCH] {ssh,sshd}_config: Include *_config.d/*.conf

Make it more convenient to supply more configurations.

Do not add more distro configurations in this patch - do so in the
*_config.d/*.conf files.
---
 ssh_config  | 3 +++
 sshd_config | 3 +++
 2 files changed, 6 insertions(+)

diff --git a/ssh_config b/ssh_config
index 238a0c5e3..e65781fde 100644
--- a/ssh_config
+++ b/ssh_config
@@ -43,3 +43,6 @@
 #   ProxyCommand ssh -q -W %h:%p gateway.example.com
 #   RekeyLimit 1G 1h
 #   UserKnownHostsFile ~/.ssh/known_hosts.d/%k
+
+# Extra configuration files, for convenience
+Include /etc/ssh/ssh_config.d/*.conf
diff --git a/sshd_config b/sshd_config
index 0f4a3a724..d003fa912 100644
--- a/sshd_config
+++ b/sshd_config
@@ -116,3 +116,6 @@ Subsystem	sftp	/usr/libexec/sftp-server
 #	AllowTcpForwarding no
 #	PermitTTY no
 #	ForceCommand cvs server
+
+# Extra configuration files, for convenience
+Include /etc/ssh/sshd_config.d/*.conf
-- 
2.53.0

