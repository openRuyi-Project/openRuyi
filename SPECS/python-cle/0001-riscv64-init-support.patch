+
+        instr &= ~0x1FFC
+        instr |= (
+            ((imm >> 10) & 1) << 12  # imm[11]
+            | ((imm >> 3) & 1) << 11  # imm[4]
+            | ((imm >> 7) & 0x3) << 9  # imm[9:8]
+            | ((imm >> 9) & 1) << 8  # imm[10]
+            | ((imm >> 5) & 1) << 7  # imm[6]
+            | ((imm >> 6) & 1) << 6  # imm[7]
+            | ((imm >> 0) & 0x7) << 3  # imm[3:1]
+            | ((imm >> 4) & 1) << 2  # imm[5]
+        )
+        self.owner.memory.pack_word(self.relative_addr, instr, size=2)
+        return True
