+class R_RISCV_ADD8(ELFReloc):
+    """
+    Relocation Type: 33
+    Calculation: V + S + A
+    """
+
+    @property
+    def value(self) -> int:
+        if self.resolvedby is None:
+            return 0
+
+        S = self.resolvedby.rebased_addr
+        A = self.addend
