# Patch purpose:
# - Remove git-dependent patch flows in third_party external CMake modules.
# Why this patch exists:
# - Packaging uses pre-unpacked source archives for third_party code.
# - Those trees have no .git metadata, so upstream "git checkout/apply" commands fail.

diff --git a/cmake/external/eigen.cmake b/cmake/external/eigen.cmake
index cfada54..744e9c1 100644
--- a/cmake/external/eigen.cmake
+++ b/cmake/external/eigen.cmake
@@ -41,13 +41,13 @@ endif()
 
 file(TO_NATIVE_PATH "${PADDLE_SOURCE_DIR}/patches/eigen/TensorRandom.h.patch"
      tensor_random_header)
-# See: [Why calling some `git` commands before `patch`?]
-set(EIGEN_PATCH_COMMAND git checkout -- . && git checkout ${EIGEN_TAG} && git
-                        apply ${tensor_random_header})
+# Sources are unpacked from archives in packaging; avoid relying on git metadata.
+set(EIGEN_PATCH_COMMAND patch -p1 -d ${SOURCE_DIR} < ${tensor_random_header})
 if(CMAKE_CXX_COMPILER_ID MATCHES "GNU|Clang")
   file(TO_NATIVE_PATH ${PADDLE_SOURCE_DIR}/patches/eigen/Complex.h.patch
        complex_header)
-  set(EIGEN_PATCH_COMMAND ${EIGEN_PATCH_COMMAND} && git apply ${complex_header})
+  set(EIGEN_PATCH_COMMAND ${EIGEN_PATCH_COMMAND} && patch -p1 -d ${SOURCE_DIR} <
+                          ${complex_header})
 endif()
 
 set(EIGEN_INCLUDE_DIR ${SOURCE_DIR})
diff --git a/cmake/external/glog.cmake b/cmake/external/glog.cmake
index 6a394ef..bd1ab7f 100755
--- a/cmake/external/glog.cmake
+++ b/cmake/external/glog.cmake
@@ -49,8 +49,7 @@ if(CMAKE_VERSION VERSION_GREATER_EQUAL "4.0.0")
 endif()
 # patch
 file(TO_NATIVE_PATH ${PADDLE_SOURCE_DIR}/patches/glog/indent.patch log_indent)
-set(GLOG_PATCH_COMMAND git checkout -- . && git apply --check ${log_indent} &&
-                       git apply ${log_indent})
+set(GLOG_PATCH_COMMAND patch -p1 -N < ${log_indent})
 ExternalProject_Add(
   extern_glog
   ${EXTERNAL_PROJECT_LOG_ARGS} ${SHALLOW_CLONE}
diff --git a/cmake/external/gloo.cmake b/cmake/external/gloo.cmake
index 734e69c..b171e73 100755
--- a/cmake/external/gloo.cmake
+++ b/cmake/external/gloo.cmake
@@ -31,8 +31,8 @@ set(GLOO_LIBRARIES
     ${GLOO_INSTALL_DIR}/lib/libgloo.a
     CACHE FILEPATH "gloo library." FORCE)
 
-# Setup gloo patch command
-set(GLOO_PATCH_COMMAND git checkout -- . && git checkout ${GLOO_TAG})
+# Setup gloo patch command without requiring git metadata
+set(GLOO_PATCH_COMMAND ${CMAKE_COMMAND} -E true)
 
 file(TO_NATIVE_PATH ${PADDLE_SOURCE_DIR}/patches/gloo/device.cc.patch
      native_dst)
diff --git a/cmake/external/gtest.cmake b/cmake/external/gtest.cmake
