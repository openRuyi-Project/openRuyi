 sysfs/fs_test.go          |  2 +-
 xfs/parse_test.go         |  2 +-
 xfs/xfs_test.go           |  4 ++--
 9 files changed, 27 insertions(+), 27 deletions(-)

diff --git a/bcache/get_test.go b/bcache/get_test.go
